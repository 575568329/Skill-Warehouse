# OpenClaw Workspace Git Ignore

# 敏感配置
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
secrets.json

# OpenClaw配置（可能包含token等敏感信息）
.openclaw/
.clawhub/

# 运行时状态文件（不需要版本控制）
memory/heartbeat-state.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.temp
*.log

# Node modules (如果有)
node_modules/

# 测试文件（可选）
test_*.png
test_*.mp4
test_*.jpg
